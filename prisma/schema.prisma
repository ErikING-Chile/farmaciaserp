generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TENANT & AUTH ====================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  rut         String?  // RUT chileno de la farmacia
  status      TenantStatus @default(ACTIVE)
  plan        String   @default("STARTER")
  isActive    Boolean  @default(true)
  settings    Json?    // Configuración específica del tenant
  featureFlags Json?   // Flags de características habilitadas
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users           User[]
  branches        Branch[]
  warehouses      Warehouse[]
  suppliers       Supplier[]
  customers       Customer[]
  products        Product[]
  categories      Category[]
  purchaseInvoices PurchaseInvoice[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  receivings      Receiving[]
  receivingItems  ReceivingItem[]
  sales           Sale[]
  stockMovements  StockMovement[]
  batches         Batch[]
  dteDocuments    DteDocument[]
  alerts          Alert[]
  alertRules      AlertRule[]
  taxRates        TaxRate[]
  supplierContacts SupplierContact[]
  supplierTerms   SupplierTerms[]
  auditLogs       AuditLog[]

  @@map("tenants")
}

model User {
  id            String    @id @default(cuid())
  email         String
  name          String?
  password      String    // Hashed
  emailVerified DateTime?
  image         String?
  isActive      Boolean   @default(true)
  role          UserRole  @default(SELLER)
  
  // Multi-tenant
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Branch assignment (optional - null means access to all)
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sales         Sale[]
  stockMovements StockMovement[]
  auditLogs     AuditLog[]
  sessions      Session[]
  accounts      Account[]

  @@unique([email, tenantId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  WAREHOUSE
  SELLER
  ACCOUNTANT
  AUDITOR
}

// ==================== ORGANIZATION ====================

model Branch {
  id          String   @id @default(uuid())
  name        String
  address     String?
  city        String?
  phone       String?
  isActive    Boolean  @default(true)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  warehouses  Warehouse[]
  sales       Sale[]
  stockMovements StockMovement[]
  batches     Batch[]
  taxRates    TaxRate[]
  alertRules  AlertRule[]
  receivings  Receiving[]
  purchaseInvoices PurchaseInvoice[]

  @@unique([name, tenantId])
  @@map("branches")
}

model Warehouse {
  id          String   @id @default(uuid())
  name        String
  type        WarehouseType @default(MAIN)
  address     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  stockMovements StockMovement[]
  batches         Batch[]
  receivings      Receiving[]

  @@unique([name, tenantId])
  @@map("warehouses")
}

enum WarehouseType {
  MAIN
  SECONDARY
  VIRTUAL
}

// ==================== SUPPLIERS & CUSTOMERS ====================

model Supplier {
  id          String   @id @default(uuid())
  name        String
  rut         String?
  legalName   String?
  tradeName   String?
  giro        String?
  contactName String?
  email       String?
  phone       String?
  address     String?
  status      SupplierStatus @default(ACTIVE)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  purchaseInvoices PurchaseInvoice[]
  receivings     Receiving[]
  contacts       SupplierContact[]
  terms          SupplierTerms?

  @@unique([name, tenantId])
  @@map("suppliers")
}

model SupplierContact {
  id          String   @id @default(uuid())
  name        String
  role        String?
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("supplier_contacts")
}

model SupplierTerms {
  id          String   @id @default(uuid())
  paymentTermDays Int @default(0)
  creditLimit Decimal? @db.Decimal(12, 2)
  currency    String   @default("CLP")
  defaultDiscountPct Decimal? @db.Decimal(5, 2)
  notes       String?

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  supplierId  String   @unique
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("supplier_terms")
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  rut         String?
  email       String?
  phone       String?
  address     String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sales       Sale[]

  @@unique([rut, tenantId])
  @@map("customers")
}

// ==================== PRODUCTS ====================

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[]

  @@unique([name, tenantId])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  sku             String
  name            String
  brand           String?
  description     String?
  unit            String   @default("UN") // UN, BOX, BLISTER, etc.
  taxCategory     TaxCategory @default(STANDARD)
  isActive        Boolean  @default(true)
  barcode         String?
  supplierCode    String?  // Código del proveedor
  
  // Stock settings
  minStock        Int      @default(0)
  maxStock        Int?
  reorderPoint    Int      @default(10)
  
  // Pricing
  baseCost        Decimal  @default(0) @db.Decimal(10, 2)
  salePrice       Decimal  @default(0) @db.Decimal(10, 2)
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  purchaseItems   PurchaseInvoiceItem[]
  saleItems       SaleItem[]
  stockMovements  StockMovement[]
  batches         Batch[]
  receivingItems  ReceivingItem[]

  @@unique([sku, tenantId])
  @@map("products")
}

enum TaxCategory {
  EXEMPT    // Exento
  STANDARD  // 19% IVA
  REDUCED   // Otros impuestos reducidos
}

// ==================== BATCHES & INVENTORY ====================

model Batch {
  id              String   @id @default(uuid())
  lotNumber       String
  expirationDate  DateTime
  initialQty      Int
  remainingQty    Int
  unitCost        Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])

  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  stockMovements  StockMovement[]
  saleAllocations SaleAllocation[]

  @@unique([lotNumber, productId, tenantId, branchId, warehouseId])
  @@map("batches")
}

model StockMovement {
  id          String   @id @default(uuid())
  type        MovementType
  quantity    Int
  qtyIn       Int      @default(0)
  qtyOut      Int      @default(0)
  unitCost    Decimal? @db.Decimal(10, 2)
  notes       String?
  
  // References
  refType     String?  // PURCHASE, SALE, ADJUSTMENT, TRANSFER
  refId       String?  // ID de la referencia
  
  // Offline sync
  syncId      String?  @unique // Idempotency key
  syncedAt    DateTime?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("stock_movements")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  PURCHASE_RECEIPT
  SALE
  RETURN
  EXPIRY_WRITE_OFF
}

// ==================== PURCHASES ====================

model PurchaseInvoice {
  id            String   @id @default(uuid())
  invoiceNumber String
  invoiceDate   DateTime
  dteType       String?  // 33 (Factura), 34 (Factura Exenta), etc.
  dteFolio      String?  // Folio del DTE
  rawXml        String?  @db.Text // XML del DTE importado
  dueDate       DateTime?
  notes         String?
  
  // Amounts
  netAmount     Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal  @default(0) @db.Decimal(10, 2)
  
  status        PurchaseStatus @default(DRAFT)
  
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  items         PurchaseInvoiceItem[]
  receivings    Receiving[]

  @@unique([invoiceNumber, tenantId])
  @@map("purchase_invoices")
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  POSTED
  CANCELLED
  ISSUED
  PAID
  VOID
}

model PurchaseInvoiceItem {
  id          String   @id @default(uuid())
  quantity    Int
  unitCost    Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  
  // Lot info from invoice
  batchLotNumber    String?
  expirationDate    DateTime?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  invoiceId   String
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  taxRateId   String?
  taxRate     TaxRate? @relation(fields: [taxRateId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("purchase_invoice_items")
}

model Receiving {
  id          String   @id @default(uuid())
  receivedAt  DateTime @default(now())
  status      ReceivingStatus @default(DRAFT)
  notes       String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  invoiceId   String?
  invoice     PurchaseInvoice? @relation(fields: [invoiceId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items       ReceivingItem[]

  @@map("receivings")
}

enum ReceivingStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

model ReceivingItem {
  id          String   @id @default(uuid())
  quantity    Int
  batchLotNumber    String
  expirationDate    DateTime
  unitCost    Decimal  @default(0) @db.Decimal(10, 2)
  notes       String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  receivingId String
  receiving   Receiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("receiving_items")
}

// ==================== SALES (POS) ====================

model Sale {
  id          String   @id @default(uuid())
  saleNumber  String   // Número correlativo de boleta/factura
  soldAt      DateTime @default(now())
  
  // Amounts
  subtotal    Decimal  @default(0) @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @default(0) @db.Decimal(10, 2)
  
  status      SaleStatus @default(OPEN)
  
  // Offline sync
  syncId      String?  @unique
  syncStatus  SyncStatus @default(SYNCED)
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items       SaleItem[]
  payments    Payment[]
  dteDocument DteDocument?

  @@map("sales")
}

enum SaleStatus {
  OPEN
  PAID
  CANCELLED
  REFUNDED
  PENDING_REVIEW // Para conflictos de sync
}

enum SyncStatus {
  SYNCED
  PENDING
  ERROR
}

model SaleItem {
  id          String   @id @default(uuid())
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  taxRate     Decimal  @default(19) @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(10, 2)
  
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  createdAt   DateTime @default(now())

  // Relations
  allocations SaleAllocation[]

  @@map("sale_items")
}

model SaleAllocation {
  id          String   @id @default(uuid())
  quantity    Int
  
  saleItemId  String
  saleItem    SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("sale_allocations")
}

model Payment {
  id          String   @id @default(uuid())
  method      PaymentMethod
  provider    PaymentProvider @default(OTHER)
  amount      Decimal  @db.Decimal(10, 2)
  reference   String?  // Voucher ID, transaction ID, etc.
  status      PaymentStatus @default(PENDING)
  
  // Webpay specific
  webpayToken String?
  webpayResponse Json?
  
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD_DEBIT
  CARD_CREDIT
  TRANSFER
  ONLINE
}

enum PaymentProvider {
  TRANSBANK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ==================== DTE / SII ====================

model DteDocument {
  id          String   @id @default(uuid())
  type        String   // 39 (Boleta), 33 (Factura), etc.
  folio       String?
  status      DteStatus @default(PENDING)
  
  xmlPayload  String?  @db.Text
  pdfUrl      String?
  siiTrackId  String?
  lastCheckedAt DateTime?
  errors      Json?    // Array de errores del SII
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  saleId      String?  @unique
  sale        Sale?    @relation(fields: [saleId], references: [id])
  
  purchaseInvoiceId String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dte_documents")
}

enum DteStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
}

// ==================== ALERTS ====================

model Alert {
  id          String   @id @default(uuid())
  type        AlertType
  severity    AlertSeverity @default(MEDIUM)
  title       String
  message     String
  isRead      Boolean  @default(false)
  entityType  String?  // PRODUCT, BATCH, etc.
  entityId    String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alerts")
}

enum AlertType {
  STOCK_LOW
  EXPIRATION_WARNING
  EXPIRED
  SYNC_ERROR
  DTE_ERROR
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ==================== AUDIT ====================

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE
  entityType  String   // Product, Sale, etc.
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model AlertRule {
  id          String   @id @default(uuid())
  type        AlertRuleType
  params      Json
  isActive    Boolean  @default(true)

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alert_rules")
}

enum AlertRuleType {
  STOCK_MIN
  EXPIRY_SOON
}

model TaxRate {
  id          String   @id @default(uuid())
  name        String
  rate        Decimal  @db.Decimal(5, 2)
  isDefault   Boolean  @default(false)

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseInvoiceItems PurchaseInvoiceItem[]

  @@unique([name, tenantId])
  @@map("tax_rates")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}
